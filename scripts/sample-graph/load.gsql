USE GRAPH social
CREATE LOADING JOB load_social FOR GRAPH social {
  DEFINE FILENAME f_person;
  DEFINE FILENAME f_friend;
  LOAD f_person TO VERTEX Person VALUES ($0, $1) USING SEPARATOR=",", HEADER="true";
  LOAD f_friend TO EDGE Friendship VALUES ($0, $1) USING SEPARATOR=",", HEADER="true";
}
RUN LOADING JOB load_social USING f_person="/home/tigergraph/data_csv/persons.csv", f_friend="/home/tigergraph/data_csv/friendships.csv"
